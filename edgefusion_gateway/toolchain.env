# EdgeFusion Gateway — 交叉编译环境（百问网 IMX6ULL buildroot 工具链）
# 用法: source toolchain.env && make
#
# 工具链已随工程自包含（./toolchain/），无需外部 SDK。
# sysroot 已预编译 FFmpeg/libcurl/libsqlite3/openssl/libjson-c（含头文件）。
# 这是 shell 脚本（被 source），用 = 而非 Makefile 的 ?=。

# 脚本所在目录（使路径与 source 位置无关，可整体移动文件夹）
EDGEFUSION_GW_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

export CROSS_TOP="$EDGEFUSION_GW_DIR/toolchain"
export CROSS_PREFIX="$CROSS_TOP/bin/arm-buildroot-linux-gnueabihf-"
export SYSROOT="$CROSS_TOP/arm-buildroot-linux-gnueabihf/sysroot"

export CC=${CROSS_PREFIX}gcc
export CXX=${CROSS_PREFIX}g++
export AR=${CROSS_PREFIX}ar
export STRIP=${CROSS_PREFIX}strip

export PKG_CONFIG_PATH=$SYSROOT/usr/lib/pkgconfig:$SYSROOT/usr/share/pkgconfig
export PKG_CONFIG_SYSROOT_DIR=$SYSROOT

# 板子部署
export BOARD_ADB_SERIAL=100ask_IMX6ULL
export BOARD_REMOTE_DIR=/mnt/extsd/gateway
